# ═══════════════════════════════════════════════════════════
# API FOR ANYTHING — Environment Configuration
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── Database ──────────────────────────────────────────────
DATABASE_URL=postgres://afa:afa_dev_password@localhost:5432/anythingapi

# ─── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── AI (Required) ────────────────────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ─── Auth ──────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-64-char-string
# Optional: Clerk integration
# CLERK_SECRET_KEY=sk_test_xxxxx
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx

# ─── Object Storage (S3/R2/MinIO) ─────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=afa_minio
S3_SECRET_KEY=afa_minio_secret
S3_BUCKET=afa-storage
S3_REGION=us-east-1

# ─── API Server ────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000

# ─── Worker ────────────────────────────────────────────────
BROWSER_POOL_SIZE=5
WORKER_CONCURRENCY=5
PROXY_ENABLED=false

# ─── Proxy (Optional — for production) ────────────────────
# PROXY_RESIDENTIAL_URL=http://user:pass@proxy.example.com:8080
# PROXY_DATACENTER_URL=http://user:pass@dc-proxy.example.com:8080

# ─── Stripe (Billing) ─────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_xxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxx
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# ─── Frontend ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# ─── Monitoring (Optional) ────────────────────────────────
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
# AXIOM_TOKEN=xxxxx
# AXIOM_DATASET=afa-logs
