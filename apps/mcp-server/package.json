{
  "name": "@afa/mcp-server",
  "version": "0.1.0",
  "private": false,
  "description": "MCP server that exposes API for Anything workflows as tools to Cursor / Claude Desktop / Windsurf",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "afa-mcp": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.1.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
