{
  "name": "anything-api",
  "version": "0.1.0",
  "private": true,
  "description": "Turn any website workflow into a callable API using AI agents",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:migrate": "turbo db:migrate --filter=@afa/db",
    "db:studio": "turbo db:studio --filter=@afa/db",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^6.0.2",
    "prettier": "^3.4.0",
    "@types/node": "^22.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
